gly disagree\" and \"10\" means strongly agree.","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Now, we want to ask you what you think about a few political topics. Some people believe in the f...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"DataVisibility":{"Private":false,"Hidden":false},"QuestionText_Unsafe":"Now, we want to ask you what you think about a few political topics. Some people believe in the following statements whereas others do not.","DataExportTag":"nonelectionstart","QuestionID":"QID341"}},{"SurveyID":"SV_3k23UO2PJvuYb66","Element":"SQ","PrimaryAttribute":"QID342","SecondaryAttribute":"For each statement please indicate how much you agree/disagree. ","TertiaryAttribute":null,"Payload":{"QuestionText":"For each statement please indicate how much you agree/disagree.&nbsp;","DefaultChoices":false,"DataExportTag":"nonelection","QuestionID":"QID342","QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","ChoiceColumnWidth":25,"RepeatHeaders":"none","WhiteSpace":"OFF","MobileFirst":true},"QuestionDescription":"For each statement please indicate how much you agree/disagree. ","Choices":{"1":{"Display":"Jeffrey Epstein, the billionaire accused of running an elite sex trafficking ring, was murdered to cover up the activities of his criminal network."},"3":{"Display":"There was a broad conspiracy, rather than a lone gunman, responsible for the assassination of President Kennedy."},"4":{"Display":"The truth about the harmful effects of vaccines is being deliberately hidden from the public."},"5":{"Display":"Regardless of who is officially in charge of governments and other organizations, there is a single group of people who secretly control events and rule the world together."}},"ChoiceOrder":[1,3,4,5],"Randomization":{"Advanced":null,"TotalRandSubset":"","Type":"All"},"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":6,"NextAnswerId":18,"Answers":{"1":{"Display":"Strongly disagree (0)"},"10":{"Display":"1"},"11":{"Display":"2"},"12":{"Display":"3"},"13":{"Display":"4"},"6":{"Display":"Neither agree nor disagree (5)"},"14":{"Display":"6"},"15":{"Display":"7"},"16":{"Display":"8"},"17":{"Display":"9"},"8":{"Display":"Strongly\nAgree (10)"}},"AnswerOrder":["1","10","11","12","13","6","14","15","16","17","8"],"ChoiceDataExportTags":{"1":"non1_epstein","3":"non2_jfk","4":"non3_vax","5":"non4_nwo"},"RecodeValues":{"1":"0","6":"5","8":"10","10":"1","11":"2","12":"3","13":"4","14":"6","15":"7","16":"8","17":"9"},"AnswerRandomization":{"Advanced":null,"ConsistentScaleReversal":true,"TotalRandSubset":"","Type":"ScaleReversal"},"QuestionJS":"Qualtrics.SurveyEngine.addOnPageSubmit(function() {\n  var SOURCE_QID = \"QID342\";\n  var ROWS = {\"1\":\"Jeffrey Epstein, the billionaire accused of running an elite sex trafficking ring, was murdered to cover up the activities of his criminal network.\",\"3\":\"There was a broad conspiracy, rather than a lone gunman, responsible for the assassination of President Kennedy.\",\"4\":\"The truth about the harmful effects of vaccines is being deliberately hidden from the public.\",\"5\":\"Regardless of who is officially in charge of governments and other organizations, there is a single group of people who secretly control events and rule the world together.\"};\n  var ANSWER_RECODE = {\"1\":0,\"6\":5,\"8\":10,\"10\":1,\"11\":2,\"12\":3,\"13\":4,\"14\":6,\"15\":7,\"16\":8,\"17\":9};\n\n  function readClaims() {\n    var raw = Qualtrics.SurveyEngine.getJSEmbeddedData(\"eligible_claims_json\");\n    if (!raw) {\n      return [];\n    }\n    try {\n      var parsed = JSON.parse(raw);\n      return Array.isArray(parsed) ? parsed : [];\n    } catch (error) {\n      return [];\n    }\n  }\n\n  function writeClaims(claims) {\n    Qualtrics.SurveyEngine.setJSEmbeddedData(\"eligible_claims_json\", JSON.stringify(claims));\n    Qualtrics.SurveyEngine.setJSEmbeddedData(\"eligible_claim_count\", String(claims.length));\n  }\n\n  function getRowScore(question, rowId) {\n    if (typeof question.getChoiceAnswerValue === \"function\") {\n      var directValue = parseInt(question.getChoiceAnswerValue(rowId), 10);\n      if (!isNaN(directValue)) {\n        return directValue;\n      }\n    }\n\n    var rowContainer = typeof question.getChoiceContainer === \"function\" ? question.getChoiceContainer(rowId) : null;\n    if (!rowContainer) {\n      return NaN;\n    }\n\n    var checkedInput = rowContainer.querySelector('input[type=\"radio\"]:checked');\n    if (!checkedInput) {\n      return NaN;\n    }\n\n    var rawValue = String(checkedInput.value || \"\");\n    if (Object.prototype.hasOwnProperty.call(ANSWER_RECODE, rawValue)) {\n      return ANSWER_RECODE[rawValue];\n    }\n\n    var parsedValue = parseInt(rawValue, 10);\n    return isNaN(parsedValue) ? NaN : parsedValue;\n  }\n\n  var nextClaims = readClaims().filter(function(entry) {\n    return entry && entry.source_qid !== SOURCE_QID;\n  });\n\n  Object.keys(ROWS).forEach(function(rowId) {\n    var score = getRowScore(this, rowId);\n    if (!isNaN(score) && score >= 6) {\n      nextClaims.push({\n        claim: ROWS[rowId],\n        score: score,\n        source_qid: SOURCE_QID,\n        row_id: rowId\n      });\n    }\n  }, this);\n\n  writeClaims(nextClaims);\n});"}},{"SurveyID":"SV_3k23UO2PJvuYb66","Element":"SQ","PrimaryAttribute":"QID343","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"QuestionType":"Timing","Selector":"PageTimer","Configuration":{"QuestionDescriptionOption":"UseText","MinSeconds":"0","MaxSeconds":"0"},"QuestionDescription":"Timing","