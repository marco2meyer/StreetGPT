oiceLocator":"q://QID262/SelectableChoice/1","Description":"<span class=\"ConjDesc\">If</span> <span class=\"QuestionDesc\">What is your present religion?</span> <span class=\"LeftOpDesc\">Protestant</span> <span class=\"OpDesc\">Is Selected</span> ","LeftOperand":"q://QID262/SelectableChoice/1","LogicType":"Question","Operator":"Selected","QuestionID":"QID262","QuestionIDFromLocator":"QID262","QuestionIsInLoop":"no","Type":"Expression"},"Type":"If"},"Type":"BooleanExpression","inPage":false},"AnalyzeChoices":{"3":"No"},"DataVisibility":{"Private":false,"Hidden":false},"RecodeValues":{"1":"2","2":"1","3":"90"}}},{"SurveyID":"SV_3k23UO2PJvuYb66","Element":"SQ","PrimaryAttribute":"QID262","SecondaryAttribute":"What is your present religion?","TertiaryAttribute":null,"Payload":{"QuestionText":"What is your present religion?","DataExportTag":"present_religion","QuestionType":"MC","Selector":"SACOL","Configuration":{"QuestionDescriptionOption":"UseText","NumColumns":2},"QuestionDescription":"What is your present religion?","Choices":{"1":{"Display":"Protestant"},"2":{"Display":"Roman Catholic"},"3":{"Display":"Muslim"},"4":{"Display":"Jewish"},"5":{"Display":"Mormon"},"6":{"Display":"Greek or Russian Orthodox"},"7":{"Display":"Buddhist"},"8":{"Display":"Hindu"},"9":{"Display":"Atheist"},"10":{"Display":"Agnostic"},"11":{"Display":"Deist"},"12":{"Display":"Something else"},"13":{"Display":"Nothing in particular"},"14":{"Display":"Prefer not to answer"}},"ChoiceOrder":["1","2","6","4","3","5","7","8","9","10","11","12","13","14"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"Language":[],"NextChoiceId":15,"NextAnswerId":1,"QuestionID":"QID262","SubSelector":"TX","AnalyzeChoices":{"14":"No"},"Randomization":{"Advanced":null,"ConsistentScaleReversal":false,"EvenPresentation":false,"TotalRandSubset":"","Type":"None"},"DataVisibility":{"Private":false,"Hidden":false}}},{"SurveyID":"SV_3k23UO2PJvuYb66","Element":"SQ","PrimaryAttribute":"QID263","SecondaryAttribute":"Please read this news article again and answer the question below. A news article that received n...","TertiaryAttribute":null,"Payload":{"QuestionText":"<u>Please read this news article again and answer the question below.</u><br />\n<br />\nA news article that received national attention recently reveals how few secret groups and powerful families shaped the course of human history. The article states that few privileged groups plotted crises that furthered their secret agendas and left the world in political and economic chaos.<br />\n<br />\nThe article states that these groups are still active, controlling almost all politicians on either side of the aisle through providing campaign funding and lobbying activities.&nbsp;<strong>This piece further argues that the only administration with the courage and will to fight against these groups was Donald Trump&#39;s administration.</strong>&nbsp;According to this piece, Donald Trump relentlessly fought against the deep state and their collaborators, including many media outlets.&nbsp;<strong>It went on to say that the ultimate aim of this secret plot is to destroy American identity and culture.</strong><br />\n<br />\n<u><em>Please answer this true-false question.</em></u><br />\n<strong>According to the news story you read, the Trump administration is claimed to work against the described plot to undermine American culture and identity.</strong>","DataExportTag":"vignette_par_repeat","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Please read this news article again and answer the question below. A news article that received n...","Choices":{"1":{"Display":"True"},"2":{"Display":"False"}},"ChoiceOrder":["1","2"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID263","DisplayLogic":{"0":{"0":{"ChoiceLocator":"q://QID222/SelectableChoice/1","Description":"<span class=\"ConjDesc\">If</span> <span class=\"QuestionDesc\">Please answer this true-false question. According to the news story you read, the Trump administr...</span> <span class=\"LeftOpDesc\">True</span> <span class=\"OpDesc\">Is Not Selected</span> ","LeftOperand":"q://QID222/SelectableChoice/1","LogicType":"Question","Operator":"NotSelected","QuestionID":"QID222","QuestionIDFromLocator":"QID222","QuestionIsInLoop":"no","Type":"Expression"},"1":{"ChoiceLocator":"q://QID185/DisplayableQuestion/1","Conjuction":"And","Description":"<span class=\"ConjDesc\">And</span> <span class=\"QuestionDesc\">A news article that received national attention recently reveals how few secret groups determined an</span> <span class=\"LeftOpDesc\"></span> <span class=\"OpDesc\">Is Displayed</span> ","LeftOperand":"q://QID185/QuestionDisplayed","LogicType":"Question","Operator":"Displayed","QuestionID":"QID185","QuestionIDFromLocator":"QID185","QuestionIsInLoop":"no","Type":"Expression"},"Type":"If"},"Type":"BooleanExpression","inPage":false},"RecodeValues":{"1":"10","2":"1"},"DataVisibility":{"Private":false,"Hidden":false}}},{"SurveyID":"SV_3k23UO2PJvuYb66","Element":"SQ","PrimaryAttribute":"QID264","SecondaryAttribute":"Please read this news article again and answer the question below. A news article that received n...","TertiaryAttribute":null,"Payload":{"QuestionText":"<u>Please read this news article again and answer the question below.</u><br />\n<br />\nA news article that received national attention recently reveals how few secret groups and powerful families shaped the course of human history. The article states that few privileged groups plotted crises that furthered their secret agendas and left the world in political and economic chaos.&nbsp;<br />\n<br />\nThe article states that these groups are still active, controlling almost all politicians on either side of the aisle through providing campaign funding and lobbying activities.&nbsp;<strong>This piece further argued that <u>no government or leader</u> has the courage or will to fight against these groups and families. Even though some honest and patriotic leaders came to power in the US, these privileged groups and families always found ways to advance their agendas.</strong><br />\n<br />\n<u><em>Please answer this true-false question.</em></u><br />\n<strong>According to the news story you read, no administration in the US has worked against the described plot by privileged groups and families.</strong>","DataExportTag":"vignetter_non_repeat","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Please read this news article again and answer the question below. A news article that received n...","Choices":{"2":{"Display":"False"},"3":{"Display":"True"}},"ChoiceOrder":["3","2"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID264","DisplayLogic":{"0":{"0":{"ChoiceLocator":"q://QID223/SelectableChoice/3","Description":"<span class=\"ConjDesc\">If</span> <span class=\"QuestionDesc\">Please answer this true-false question. According to the news story you read, no administration i...</span> <span class=\"LeftOpDesc\">True</span> <span class=\"OpDesc\">Is Not Selected</span> ","LeftOperand":"q://QID223/SelectableChoice/3","LogicType":"Question","Operator":"NotSelected","QuestionID":"QID223","QuestionIDFromLocator":"QID223","QuestionIsInLoop":"no","Type":"Expression"},"1":{"ChoiceLocator":"q://QID186/DisplayableQuestion/1","Conjuction":"And","Description":"<span class=\"ConjDesc\">And</span> <span class=\"QuestionDesc\">A news article that received national attention recently reveals how few secret groups and powerful families shaped the course of human history. The article states that few privileged groups plotte...</span> <span class=\"LeftOpDesc\"></span> <span c