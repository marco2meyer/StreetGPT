tion":"<span class=\"ConjDesc\">If</span> <span class=\"QuestionDesc\">A news article that received national attention recently reveals how few secret groups and powerful families shaped the course of human history. The article states that few privileged groups plotte...</span> <span class=\"LeftOpDesc\"></span> <span class=\"OpDesc\">Is Displayed</span> ","LeftOperand":"q://QID186/QuestionDisplayed","LogicType":"Question","Operator":"Displayed","QuestionID":"QID186","QuestionIDFromLocator":"QID186","QuestionIsInLoop":"no","Type":"Expression"},"Type":"If"},"Type":"BooleanExpression","inPage":false},"RecodeValues":{"1":"1","3":"10"}}},{"SurveyID":"SV_3k23UO2PJvuYb66","Element":"SQ","PrimaryAttribute":"QID224","SecondaryAttribute":"For each statement please indicate how much you agree/disagree. ","TertiaryAttribute":null,"Payload":{"QuestionText":"For each statement please indicate how much you agree/disagree.&nbsp;","DefaultChoices":false,"DataExportTag":"Republican CTs1","QuestionID":"QID224","QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","ChoiceColumnWidth":25,"RepeatHeaders":"none","WhiteSpace":"OFF","MobileFirst":true},"QuestionDescription":"For each statement please indicate how much you agree/disagree. ","Choices":{"2":{"Display":"Election fraud was widespread enough to influence the outcome of the 2020 Presidential Elections in favor of Joe Biden."},"5":{"Display":"There are many, please choose \"4\" for this statement."},"8":{"Display":"Democrats organize non-citizens (e.g., undocumented immigrants) to vote illegally in U.S. elections to rig elections."},"10":{"Display":"Democrats commit widespread voter fraud in U.S. elections through manipulating mail-in voting and voting machines."}},"ChoiceOrder":[2,5,8,10],"Randomization":{"Type":"Advanced","Advanced":{"FixedOrder":["{~Randomized~}","{~Randomized~}","5","{~Randomized~}"],"RandomizeAll":["2","8","10"],"RandomSubSet":[],"ScaleReversal":[],"Undisplayed":[],"TotalRandSubset":0},"ConsistentScaleReversal":true,"EvenPresentation":false,"TotalRandSubset":""},"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"RecodeValues":{"13":"0","14":"1","15":"2","16":"3","20":"4","21":"5","22":"6","23":"7","24":"8","25":"9","26":"10"},"GradingData":[],"Language":[],"NextChoiceId":11,"NextAnswerId":27,"Answers":{"13":{"Display":"Strongly disagree (0)"},"14":{"Display":"1"},"15":{"Display":"2"},"16":{"Display":"3"},"20":{"Display":"4"},"21":{"Display":"Neither agree nor disagree (5)"},"22":{"Display":"6"},"23":{"Display":"7"},"24":{"Display":"8"},"25":{"Display":"9"},"26":{"Display":"Strongly agree (10)"}},"AnswerOrder":["13","14","15","16","20","21","22","23","24","25","26"],"ChoiceDataExportTags":{"2":"rep1_2020","5":"att1_repCTs","8":"rep2_noncitizens","10":"rep3_mailmach"},"AnswerRandomization":{"Advanced":null,"ConsistentScaleReversal":true,"TotalRandSubset":"","Type":"ScaleReversal"},"QuestionJS":"Qualtrics.SurveyEngine.addOnPageSubmit(function() {\n  var SOURCE_QID = \"QID224\";\n  var ROWS = {\"2\":\"Election fraud was widespread enough to influence the outcome of the 2020 Presidential Elections in favor of Joe Biden.\",\"8\":\"Democrats organize non-citizens (e.g., undocumented immigrants) to vote illegally in U.S. elections to rig elections.\",\"10\":\"Democrats commit widespread voter fraud in U.S. elections through manipulating mail-in voting and voting machines.\"};\n  var ANSWER_RECODE = {\"13\":0,\"14\":1,\"15\":2,\"16\":3,\"20\":4,\"21\":5,\"22\":6,\"23\":7,\"24\":8,\"25\":9,\"26\":10};\n\n  function readClaims() {\n    var raw = Qualtrics.SurveyEngine.getJSEmbeddedData(\"eligible_claims_json\");\n    if (!raw) {\n      return [];\n    }\n    try {\n      var parsed = JSON.parse(raw);\n      return Array.isArray(parsed) ? parsed : [];\n    } catch (error) {\n      return [];\n    }\n  }\n\n  function writeClaims(claims) {\n    Qualtrics.SurveyEngine.setJSEmbeddedData(\"eligible_claims_json\", JSON.stringify(claims));\n    Qualtrics.SurveyEngine.setJSEmbeddedData(\"eligible_claim_count\", String(claims.length));\n  }\n\n  function getRowScore(question, rowId) {\n    if (typeof question.getChoiceAnswerValue === \"function\") {\n      var directValue = parseInt(question.getChoiceAnswerValue(rowId), 10);\n      if (!isNaN(directValue)) {\n        return directValue;\n      }\n    }\n\n    var rowContainer = typeof question.getChoiceContainer === \"function\" ? question.getChoiceContainer(rowId) : null;\n    if (!rowContainer) {\n      return NaN;\n    }\n\n    var checkedInput = rowContainer.querySelector('input[type=\"radio\"]:checked');\n    if (!checkedInput) {\n      return NaN;\n    }\n\n    var rawValue = String(checkedInput.value || \"\");\n    if (Object.prototype.hasOwnProperty.call(ANSWER_RECODE, rawValue)) {\n      return ANSWER_RECODE[rawValue];\n    }\n\n    var parsedValue = parseInt(rawValue, 10);\n    return isNaN(parsedValue) ? NaN : parsedValue;\n  }\n\n  var nextClaims = readClaims().filter(function(entry) {\n    return entry && entry.source_qid !== SOURCE_QID;\n  });\n\n  Object.keys(ROWS).forEach(function(rowId) {\n    var score = getRowScore(this, rowId);\n    if (!isNaN(score) && score >= 6) {\n      nextClaims.push({\n        claim: ROWS[rowId],\n        score: score,\n        source_qid: SOURCE_QID,\n        row_id: rowId\n      });\n    }\n  }, this);\n\n  writeClaims(nextClaims);\n});"}},{"SurveyID":"SV_3k23UO2PJvuYb66","Element":"SQ","PrimaryAttribute":"QID225","SecondaryAttribute":"For each statement please indicate how much you agree/disagree.","TertiaryAttribute":null,"Payload":{"QuestionText":"For each statement please indicate how much you agree/disagree.","DefaultChoices":false,"DataExportTag":"Republican CTs2","QuestionID":"QID225","QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","Configur