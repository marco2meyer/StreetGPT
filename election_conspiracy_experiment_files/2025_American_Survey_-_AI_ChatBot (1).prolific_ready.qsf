rong>Definitely not</strong> true"},"5":{"Display":"Don't know/Prefer not to answer"}},"ChoiceOrder":[1,2,3,4,5],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"Language":[],"NextChoiceId":6,"NextAnswerId":1,"QuestionID":"QID180","DataVisibility":{"Private":false,"Hidden":false},"RecodeValues":{"1":"4","2":"3","3":"2","4":"1","5":"90"},"AnalyzeChoices":{"5":"No"}}},{"SurveyID":"SV_3k23UO2PJvuYb66","Element":"SQ","PrimaryAttribute":"QID181","SecondaryAttribute":"Some people believe that leaked emails from Hillary Clinton’s 2016 presidential election campaign.","TertiaryAttribute":null,"Payload":{"QuestionText":"Some people believe that leaked emails from Hillary Clinton’s 2016 presidential election campaign contained code words for pedophilia, human trafficking and\nsatanic ritual abuse - what some people refer to as '<strong>Pizzagate</strong>'. Others do not believe this. What do you think?","DataExportTag":"rep_pizzagate","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Some people believe that leaked emails from Hillary Clinton’s 2016 presidential election campaign...","Choices":{"1":{"Display":"Pizzagate is <strong>definitely </strong>true"},"2":{"Display":"Pizzagate is <strong>probably </strong>true"},"3":{"Display":"Pizzagate is <strong>probably not</strong> true"},"4":{"Display":"Pizzagate is <strong>definitely not</strong> true"},"5":{"Display":"Don't know/Prefer not to answer"}},"ChoiceOrder":["1","2","3","4","5"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"Language":[],"NextChoiceId":6,"NextAnswerId":1,"QuestionID":"QID181","DataVisibility":{"Private":false,"Hidden":false},"RecodeValues":{"1":"4","2":"3","3":"2","4":"1","5":"90"},"GradingData":[],"AnalyzeChoices":{"5":"No"}}},{"SurveyID":"SV_3k23UO2PJvuYb66","Element":"SQ","PrimaryAttribute":"QID182","SecondaryAttribute":"Some people believe that the U.S interfered in the Middle East primarily because of its oil inter...","TertiaryAttribute":null,"Payload":{"QuestionText":"Some people believe that the U.S interfered in the Middle East primarily&nbsp;because&nbsp;of its oil interests. Others do not believe this. What do you think?","DataExportTag":"dem_oil","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Some people believe that the U.S interfered in the Middle East primarily because of its oil inter...","Choices":{"1":{"Display":"<strong>Definitely </strong>true"},"2":{"Display":"<strong>Probably </strong>true"},"3":{"Display":"<strong>Probably not</strong> true"},"4":{"Display":"<strong>Definitely not</strong> true"},"5":{"Display":"Don't know/Prefer not to answer"}},"ChoiceOrder":["1","2","3","4","5"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"Language":[],"NextChoiceId":6,"NextAnswerId":1,"QuestionID":"QID182","DataVisibility":{"Private":false,"Hidden":false},"RecodeValues":{"1":"4","2":"3","3":"2","4":"1","5":"90"},"AnalyzeChoices":{"5":"No"}}},{"SurveyID":"SV_3k23UO2PJvuYb66","Element":"SQ","PrimaryAttribute":"QID183","SecondaryAttribute":"Click to write the question text","TertiaryAttribute":null,"Payload":{"QuestionText":"Click to write the question text","DataExportTag":"Q98","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Click to write the question text","Choices":{"1":{"Display":"Click to write Choice 1"},"2":{"Display":"Click to write Choice 2"},"3":{"Display":"Click to write Choice 3"}},"ChoiceOrder":["1","2","3"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID183"}},{"SurveyID":"SV_3k23UO2PJvuYb66","Element":"SQ","PrimaryAttribute":"QID184","SecondaryAttribute":"Click to write the question text","TertiaryAttribute":null,"Payload":{"QuestionText":"Click to write the question text","DefaultChoices":false,"DataExportTag":"Q99","QuestionID":"QID184","QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","ChoiceColumnWidth":25,"RepeatHeaders":"none","WhiteSpace":"OFF","MobileFirst":true},"QuestionDescription":"Click to write the question text","Choices":{"1":{"Display":"Click to write Statement 1"},"2":{"Display":"Click to write Statement 2"},"3":{"Display":"Click to write Statement 3"}},"ChoiceOrder":["1","2","3"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":4,"Answers":{"1":{"Display":"Strongly disagree"},"2":{"Display":"Click to write Scale Point 2"},"3":{"Display":"Click to write Scale Point 3"}},"AnswerOrder":["1","2","3"],"ChoiceDataExportTags":false}},{"SurveyID":"SV_3k23UO2PJvuYb66","Element":"SQ","PrimaryAttribute":"QID185","SecondaryAttribute":"A news article that received national attention recently reveals how few secret groups determined an","TertiaryAttribute":null,"Payload":{"QuestionText":"A news article that received national attention recently reveals how few secret groups and powerful families shaped the course of human history. The article states that few privileged groups plotted crises that furthered their secret agendas and left the world in political and economic chaos.&nbsp;<br>\n<br>\nThe article states that these groups are still active, controlling almost all politicians on either side of the aisle through providing campaign funding and lobbying activities. <strong>This piece further argues that the only administration with the courage and will to fight against these groups was Donald Trump's administration.</strong> According to this piece, Donald Trump relentlessly fought against the deep state and their collaborators, including many media outlets. <strong>It went on to say that the ultimate aim of this secret plot is to destroy American identity and culture.&nbsp;</strong><br>\n<span style=\"font-size:13px;\"><u><em>(Do not refresh your page, proceed option will be visible in 30 seconds.)</em></u></span>","DefaultChoices":false,"DataExportTag":"vignette_partisan","QuestionID":"QID185","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"SpecifyLabel"},"QuestionDescription":"A news article that received national attention recently reveals how few secret groups determined an","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":74,"NextAnswerId":1}},{"SurveyID":"SV_3k23UO2PJvuYb66","Element":"SQ","PrimaryAttribute":"QID186","SecondaryAttribute":"A news article that received national attention recently reveals how few secret groups and powerf...","TertiaryAttribute":null,"Payload":{"QuestionText":"A news article that received national attention recently reveals how few secret groups and powerful families shaped the course of human history. The article states that few privileged groups plotted crises that furthered their secret agendas and left the world in political and economic chaos.&nbsp;<br>\n<br>\nThe article states that these groups are still active, controlling almost all politicians on either side of the aisle through providing campaign funding and lobbying activities.&nbsp;<strong>This piece further argued that <u>no government or leader </u>has the courage or will to fight against these groups and families. Even though some honest and patriotic leaders came to power in the US, these privileged groups and families always found ways to advance their agendas.</strong><br>\n<span style=\"font-size:13px;\"><u><em>(Do not refresh your page, proceed option will be visible in 30 seconds.)</em></u></span>","DefaultChoices":false,"DataExportTag":"vignette_non","QuestionID":"QID186