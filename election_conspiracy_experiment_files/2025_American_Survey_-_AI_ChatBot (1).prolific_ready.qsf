tyle=\"text-align: left;\">Unlikely</div>"},"2":{"Display":"<div style=\"text-align: right;\">Extremely<br />\nLikely</div>\n"}}}},{"SurveyID":"SV_3k23UO2PJvuYb66","Element":"SQ","PrimaryAttribute":"QID390","SecondaryAttribute":"Would you agree that this country needs a strong leader who does not have to bother with Congress...","TertiaryAttribute":null,"Payload":{"QuestionText":"Would you agree that this country needs a strong leader who does not have to bother with Congress or elections?","DefaultChoices":false,"DataExportTag":"exp_auth","QuestionID":"QID390","QuestionType":"Slider","Selector":"HSLIDER","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","CSSliderMin":0,"CSSliderMax":10,"GridLines":10,"SnapToGrid":true,"NumDecimals":"0","ShowValue":true,"CustomStart":true,"NotApplicable":false,"MobileFirst":true,"SliderStartPositions":{"9":0.4932330827067669}},"QuestionDescription":"Would you agree that this country needs a strong leader who does not have to bother with Congress...","Choices":{"9":{"Display":"<span style=\"color:#ffffff;\">S</span>"}},"ChoiceOrder":["9"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":16,"NextAnswerId":3,"Labels":{"1":{"Display":"<div style=\"text-align: left;\">Strongly</div>\n\n<div style=\"text-align: left;\">Disagree</div>"},"2":{"Display":"<div style=\"text-align: right;\">Strongly<br />\nAgree</div>\n"}},"Answers":{"1":{"Display":0},"2":{"Display":1},"3":{"Display":2},"4":{"Display":3},"5":{"Display":4},"6":{"Display":5},"7":{"Display":6},"8":{"Display":7},"9":{"Display":8},"10":{"Display":9},"11":{"Display":10}}}},{"SurveyID":"SV_3k23UO2PJvuYb66","Element":"SQ","PrimaryAttribute":"QID391","SecondaryAttribute":"What do you think, is the candidate a Democrat or a Republican?","TertiaryAttribute":null,"Payload":{"QuestionText":"What do you think, is the candidate a Democrat or a Republican?","DataExportTag":"exp_party","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"What do you think, is the candidate a Democrat or a Republican?","Choices":{"1":{"Display":"A Democrat"},"2":{"Display":"A Republican"},"3":{"Display":"Not sure"}},"ChoiceOrder":["1","2","3"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"Language":[],"NextChoiceId":5,"NextAnswerId":1,"QuestionID":"QID391"}},{"SurveyID":"SV_3k23UO2PJvuYb66","Element":"SQ","PrimaryAttribute":"QID392","SecondaryAttribute":"Please read this brief statement from a politician’s speech. This statement was made during their.","TertiaryAttribute":null,"Payload":{"QuestionText":"Please read this brief statement from a politician&rsquo;s speech. This statement was made during their political campaign when they were running for office.<br />\n<br />\n<em>&quot;We now know there is a global group of wealthy and well-connected elites who try to influence politics behind the scenes, and without regard for ordinary citizens.<br />\nIf you vote for me, I will strengthen democratic institutions and enforce the rule of law to ensure government represents all citizens, not just the powerful.&quot;</em>","DefaultChoices":false,"DataExportTag":"struc_lib","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Please read this brief statement from a politician’s speech. This statement was made during their...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID392"}},{"SurveyID":"SV_3k23UO2PJvuYb66","Element":"SQ","PrimaryAttribute":"QID393","SecondaryAttribute":"Please read this brief statement from a politician’s speech. This statement was made during their.","TertiaryAttribute":null,"Payload":{"QuestionText":"Please read this brief statement from a politician’s speech. This statement was made\nduring their political campaign when they were running for office.","DefaultChoices":false,"DataExportTag":"Q296","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Please read this brief statement from a politician’s speech. This statement was made during their...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID393"}},{"SurveyID":"SV_3k23UO2PJvuYb66","Element":"SQ","PrimaryAttribute":"QID394","SecondaryAttribute":"Please read this brief statement from a politician’s speech. This statement was made during their.","TertiaryAttribute":null,"Payload":{"QuestionText":"Please read this brief statement from a politician&rsquo;s speech. This statement was made during their political campaign when they were running for office.<br />\n<br />\n<em>&quot;We now know there is a global group of wealthy and well-connected elites who try to influence politics behind the scenes, and without regard for ordinary citizens.<br />\nIf you vote for me, I will use the full power of the state to dismantle their networks and impose decisions that put the nation first, no matter who stands in the way.&quot;</em>","DefaultChoices":false,"DataExportTag":"struc_auth","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Please read this brief statement from a politician’s speech. This statement was made during their...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID394"}},{"SurveyID":"SV_3k23UO2PJvuYb66","Element":"SQ","PrimaryAttribute":"QID395","SecondaryAttribute":"If you vote for me, I wil