s"},"28":{"Display":"White people"}},"ChoiceOrder":["26","27","28"],"Randomization":{"Advanced":null,"ConsistentScaleReversal":true,"TotalRandSubset":"","Type":"ScaleReversal"},"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":29,"NextAnswerId":10,"Answers":{"1":{"Display":"Change much","ExclusiveAnswer":true},"2":{"Display":"Change little","ExclusiveAnswer":true}},"AnswerOrder":[1,2],"AnswerColumns":2,"ChoiceDataExportTags":false,"QuestionID":"QID127","ClarifyingSymbolType":"None","SubSelector":"SingleAnswer"}},{"SurveyID":"SV_3k23UO2PJvuYb66","Element":"SQ","PrimaryAttribute":"QID128","SecondaryAttribute":"Some groups have an underlying reality; although their members have similarities and differences...","TertiaryAttribute":null,"Payload":{"QuestionText":"Some groups have an underlying reality; although their members have similarities and\ndifferences on the surface, underneath they are basically the same. Other groups also have similarities\nand differences on the surface, but do not correspond to an underlying reality.<div>('underlying reality or sameness' vs. 'no underlying reality or sameness').</div>","DefaultChoices":false,"DataExportTag":"Inherence","QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","ChoiceColumnWidth":25,"RepeatHeaders":"none","WhiteSpace":"OFF","MobileFirst":true},"QuestionDescription":"Some groups have an underlying reality; although their members have similarities and differences...","Choices":{"26":{"Display":"Democrats"},"27":{"Display":"Republicans"},"28":{"Display":"White people"}},"ChoiceOrder":["26","27","28"],"Randomization":{"Advanced":null,"ConsistentScaleReversal":true,"TotalRandSubset":"","Type":"ScaleReversal"},"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":29,"NextAnswerId":12,"Answers":{"1":{"Display":"Basically the same","ExclusiveAnswer":true},"2":{"Display":"Somewhat similar","ExclusiveAnswer":true},"10":{"Display":"Not that similar"},"11":{"Display":"Not similar at all"}},"AnswerOrder":[1,2,"10","11"],"ChoiceDataExportTags":false,"QuestionID":"QID128"}},{"SurveyID":"SV_3k23UO2PJvuYb66","Element":"SQ","PrimaryAttribute":"QID129","SecondaryAttribute":"Some categories have necessary features or characteristics; without these characteristics someone...","TertiaryAttribute":null,"Payload":{"QuestionText":"Some categories have necessary features or characteristics; without these characteristics\nsomeone cannot be a category member. Other categories have many similarities, but no features or\ncharacteristics are necessary for membership<div>('necessary features or characteristics' vs. 'no necessary\nfeatures or characteristics')</div>","DefaultChoices":false,"DataExportTag":"Necessity","QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","ChoiceColumnWidth":25,"RepeatHeaders":"none","WhiteSpace":"OFF","MobileFirst":true},"QuestionDescription":"Some categories have necessary features or characteristics; without these characteristics someone...","Choices":{"26":{"Display":"Democrats"},"27":{"Display":"Republicans"},"28":{"Display":"White people"}},"ChoiceOrder":["26","27","28"],"Randomization":{"Advanced":null,"Type":"ScaleReversal","ConsistentScaleReversal":true,"TotalRandSubset":""},"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":29,"NextAnswerId":10,"Answers":{"1":{"Display":"Necessary Features","ExclusiveAnswer":true},"2":{"Display":"NO Necessary features","ExclusiveAnswer":true}},"AnswerOrder":[1,2],"ChoiceDataExportTags":false,"QuestionID":"QID129"}},{"SurveyID":"SV_3k23UO2PJvuYb66","Element":"SQ","PrimaryAttribute":"QID130","SecondaryAttribute":"Some categories do not allow their members to belong to other categories; belonging to such a cat...","TertiaryAttribute":null,"Payload":{"QuestionText":"Some categories do not allow their members to belong to other categories; belonging to\r\nsuch a category excludes a person from these other categories. On the other hand, some categories do\r\nnot limit which other categories their members can belong to; they do not exclude a person from these\r\ncategories.<div>('exclude other categories' vs. 'not exclude other categories')</div>","DefaultChoices":false,"DataExportTag":"Exclusivity","QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","ChoiceColumnWidth":25,"RepeatHeaders":"none","WhiteSpace":"OFF","MobileFirst":true},"QuestionDescription":"Some categories do not allow their members to belong to other categories; belonging to such a cat...","Choices":{"26":{"Display":"Democrats"},"27":{"Display":"Republicans"},"28":{"Display":"White people"}},"ChoiceOrder":["26","27","28"],"Randomization":{"Advanced":null,"Type":"ScaleReversal","ConsistentScaleReversal":true,"TotalRandSubset":""},"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":29,"NextAnswerId":10,"Answers":{"1":{"Display":"Exclude","ExclusiveAnswer":true},"2":{"Display":"NOT Exclude","ExclusiveAnswer":true}},"AnswerOrder":[1,2],"ChoiceDataExportTags":false,"QuestionID":"QID130"}},{"SurveyID":"SV_3k23UO2PJvuYb66","Element":"SQ","PrimaryAttribute":"QID131","SecondaryAttribute":"We are going to describe various types of political systems and ask what you think about each as...","TertiaryAttribute":null,"Payload":{"QuestionText":"We are going to describe various types of political systems and ask what you think about each as a way of governing this country. For each statement, please indicate how strongly you agree/disagree to the following statements.","DefaultChoices":false,"DataExportTag":"sfd","QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","ChoiceColumnWidth":25,"RepeatHeaders":"none","WhiteSpace":"OFF","MobileFirst":true,"ChoiceColumnWidthPixels":333},"QuestionDescription":"We are going to describe various types of political systems and ask what you think about each as...","Choices":{"1":{"Display":"Having a democratic political system"},"2":{"Display":"Having a strong leader who does not have to bother with parliament and elections."},"3":{"Display":"Having experts, not the government, make decisions according to what they think is best for the country"},"4":{"Display":"Having the army rule"}},"ChoiceOrder":["1","2","3","4"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":7,"NextAnswerId":11,"Answers":{"5":{"Display":"Strongly disagree"},"6":{"Display":"Somewhat disagree"},"8":{"Display":"Somewhat agree"},"9":{"Display":"Strongly agree"},"10":{"Display":"Prefer not to answer"}},"AnswerOrder":["5","6","8","9","10"],"ChoiceDataExportTags":{"1":"sfd1","2":"sfd2","3":"sfd3","4":"sfd4"},"QuestionID":"QID131","DataVisibility":{"Private":false,"Hidden":false},"AnalyzeChoices":{"10":"No"},"Randomization":{"Advanced":null,"TotalRandSubset":"","Type":"All"},"RecodeValues":{"5":"1","6":"2","8":"3","9":"4","10":"90"}}},{"SurveyID":"SV_3k23UO2PJvuYb66","Element":"SQ","PrimaryAttribute":"QID132","SecondaryAttribute":"You are doing great! Let's move to another topic. In this section, we have statements about how...","TertiaryAttribute":null,"Payload":{"AnswerOrder":["15","16","18","19","20"],"Answers":{"15":{"Display":"Strongly disagree"},"16":{"Display":"Somewhat disagree"},"18":{"Display":"Somewhat agree"},"19":{"Display":"Strongly agree"},"20":{"Display":"Prefer not to answer"}},"ChoiceDataExportTags":{"1":"mental_1","2":"mental_2","3":"mental_3","4":"mental_4","5":"mental_5"},"ChoiceOrder":["1","2","3","4","5"],"Choices":{"1":{"Display":"There are secret organizations that greatly influence political decisions."},"2":{"Display":"Politicians usually do not tell us the true motives for their decisions."},"3":{"Display":"Government agencies closely monitor all citizens."},"4":{"Display":"Events that superficially seem to lack a connection are often the result of secret activities."},"5":{"Display":"Many very important things happen in the world, which the public is never informed about."}},"Configuration":{"ChoiceColumnWidthPixels":316,"MobileFirst":true,"QuestionDescriptionOption":"UseText","RepeatHeaders":"none","TextPosition":"inline","WhiteSpace":"OFF"},"DataExportTag":"mental","DataVisibility":{"Hidden":false,"Private":false},"DefaultChoices":false,"GradingData":[],"Language":[],"NextAnswerId":21,"NextChoiceId":6,"QuestionDescription":"You are doing great! Let's move to another topic. In this section, we have statements about how...","QuestionID":"QID132","QuestionText":"&nbsp;You are doing great! Let's move to another topic. In this section, we have statements about how politics works. We'd like to know what you think. Please indicate how strongly you agree/disagree with the following statements.","QuestionText_Unsafe":"You are doing great! Let's move to another topic. In this section, we have statements about how politics works. We'd like to know what you think?&nbsp;","QuestionType":"Matrix","Randomization":{"Advanced":null,"TotalRandSubset":"","Type":"All"},"RecodeValues":{"15":1,"16":2,"18":"3","19":"4","20":"90"},"Selector":"Likert","SubSelector":"SingleAnswer","Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"AnalyzeChoices":{"20":"No"}}},{"SurveyID":"SV_3k23UO2PJvuYb66","Element":"SQ","PrimaryAttribute":"QID133","SecondaryAttribute":"We are curious about your opinions on politics. For each statement, please indicate how strongly...","TertiaryAttribute":null,"Payload":{"QuestionText":"We are curious about your opinions on politics. For each statement, please indicate how strongly you agree/disagree to the following statements.","DefaultChoices":false,"DataExportTag":"rwa","QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","ChoiceColumnWidth":25,"RepeatHeaders":"none","WhiteSpace":"OFF","MobileFirst":true,"ChoiceColumnWidthPixels":464},"QuestionDescription":"We are curious about your opinions on politics. For each statement, please indicate how strongly...","Choices":{"1":{"Display":"What our country really needs is a strong, determined leader who will crush evil and take us back to our true path."},"2":{"Display":"What people call compromise in politics is really just selling out on one’s principles."},"3":{"Display":"Having a strong leader in government is good for the US even if the leader bends the rules to get things done."},"4":{"Display":"Minorities should adapt to the customs and traditions of the US."},"5":{"Display":"The will of the majority should always prevail, even over the rights of the minorities."},"6":{"Display":"Our country would be great if we honor the ways of our forefathers, do what the authorities tell us to do, and get rid of the ‘rotten apples’ who are ruining everything."}},"ChoiceOrder":["1","2","3","4","5","6"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":7,"NextAnswerId":8,"Answers":{"1":{"Display":"Strongly disagree"},"2":{"Display":"Disagree"},"3":{"Display":"Somewhat disagree"},"4":{"Display":"Somewhat agree"},"5":{"Display":"Agree"},"6":{"Display":"Strongly agree"},"7":{"Display":"Prefer not to answer"}},"An