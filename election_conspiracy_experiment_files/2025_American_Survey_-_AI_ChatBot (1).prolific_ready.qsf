hoiceLocator":"q://QID236/SelectableChoice/1","Operator":"Selected","QuestionIDFromLocator":"QID236","LeftOperand":"q://QID236/SelectableChoice/1","Type":"Expression","Description":"<span class=\"ConjDesc\">If</span> <span class=\"QuestionDesc\">Here is a fun fact for you before we move on to other questions. Santa Claus is real! Santa's myt...</span> <span class=\"LeftOpDesc\">Proceed</span> <span class=\"OpDesc\">Is Selected</span> "},"Type":"If"},"Type":"BooleanExpression","inPage":false}}},{"SurveyID":"SV_3k23UO2PJvuYb66","Element":"SQ","PrimaryAttribute":"QID272","SecondaryAttribute":"For each statement please indicate how much you agree/disagree.","TertiaryAttribute":null,"Payload":{"QuestionText":"For each statement please indicate how much you agree/disagree.","DefaultChoices":false,"DataExportTag":"Democratic CTs 1","QuestionID":"QID272","QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","ChoiceColumnWidth":25,"RepeatHeaders":"none","WhiteSpace":"OFF","MobileFirst":true},"QuestionDescription":"For each statement please indicate how much you agree/disagree.","Choices":{"1":{"Display":"Elon Musk's company, SpaceX, used its Starlink satellite technology to manipulate election results during the 2024 U.S. presidential election."},"2":{"Display":"Donald Trump's campaign team coordinated with the Russian government to interfere in the 2016 Presidential Election."},"3":{"Display":"Republicans won the presidential elections in 2016, 2004, and 2000 by stealing them."},"4":{"Display":"Election fraud was widespread enough to influence the outcome of the 2024 Presidential Elections in favor of Donald Trump."}},"ChoiceOrder":[1,2,3,4],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":5,"NextAnswerId":13,"Answers":{"1":{"Display":"Strongly disagree (0)"},"2":{"Display":"1"},"3":{"Display":"2"},"4":{"Display":"3"},"5":{"Display":"4"},"6":{"Display":"Neither agree nor disagree (5)"},"8":{"Display":"6"},"9":{"Display":"7"},"10":{"Display":"8"},"11":{"Display":"9"},"12":{"Display":"Strongly agree (10)"}},"AnswerOrder":[1,2,3,4,5,6,"8","9","10","11","12"],"ChoiceDataExportTags":{"1":"dem1_elon","2":"dem2_russia","3":"dem3_elections","4":"dem4_2024"},"RecodeValues":{"1":"0","2":"1","3":"2","4":"3","5":"4","6":"5","8":"6","9":"7","10":"8","11":"9","12":"10"},"QuestionJS":"Qualtrics.SurveyEngine.addOnPageSubmit(function() {\n  var SOURCE_QID = \"QID272\";\n  var ROWS = {\"1\":\"Elon Musk's company, SpaceX, used its Starlink satellite technology to manipulate election results during the 2024 U.S. presidential election.\",\"2\":\"Donald Trump's campaign team coordinated with the Russian government to interfere in the 2016 Presidential Election.\",\"3\":\"Republicans won the presidential elections in 2016, 2004, and 2000 by stealing them.\"};\n  var ANSWER_RECODE = {\"1\":0,\"2\":1,\"3\":2,\"4\":3,\"5\":4,\"6\":5,\"8\":6,\"9\":7,\"10\":8,\"11\":9,\"12\":10};\n\n  function readClaims() {\n    var raw = Qualtrics.SurveyEngine.getJSEmbeddedData(\"eligible_claims_json\");\n    if (!raw) {\n      return [];\n    }\n    try {\n      var parsed = JSON.parse(raw);\n      return Array.isArray(parsed) ? parsed : [];\n    } catch (error) {\n      return [];\n    }\n  }\n\n  function writeClaims(claims) {\n    Qualtrics.SurveyEngine.setJSEmbeddedData(\"eligible_claims_json\", JSON.stringify(claims));\n    Qualtrics.SurveyEngine.setJSEmbeddedData(\"eligible_claim_count\", String(claims.length));\n  }\n\n  function getRowScore(question, rowId) {\n    if (typeof question.getChoiceAnswerValue === \"function\") {\n      var directValue = parseInt(question.getChoiceAnswerValue(rowId), 10);\n      if (!isNaN(directValue)) {\n        return directValue;\n      }\n    }\n\n    var rowContainer = typeof question.getChoiceContainer === \"function\" ? question.getChoiceContainer(rowId) : null;\n    if (!rowContainer) {\n      return NaN;\n    }\n\n    var checkedInput = rowContainer.querySelector('input[type=\"radio\"]:checked');\n    if (!checkedInput) {\n      return NaN;\n    }\n\n    var rawValue = String(checkedInput.value || \"\");\n    if (Object.prototype.hasOwnProperty.call(ANSWER_RECODE, rawValue)) {\n      return ANSWER_RECODE[rawValue];\n    }\n\n    var parsedValue = parseInt(rawValue, 10);\n    return isNaN(parsedValue) ? NaN : parsedValue;\n  }\n\n  var nextClaims = readClaims().filter(function(entry) {\n    return entry && entry.source_qid !== SOURCE_QID;\n  });\n\n  Object.keys(ROWS).forEach(function(rowId) {\n    var score = getRowScore(this, rowId);\n    if (!isNaN(score) && score >= 6) {\n      nextClaims.push({\n        claim: ROWS[rowId],\n        score: score,\n        source_qid: SOURCE_QID,\n        row_id: rowId\n      });\n    }\n  }, this);\n\n  writeClaims(nextClaims);\n});"}},{"SurveyID":"SV_3k23UO2PJvuYb66","Element":"SQ","PrimaryAttribute":"QID273","SecondaryAttribute":"Some people have opinions about almost everything; other people have opinions about just some thi...","TertiaryAttribute":null,"Payload":{"QuestionText":"Some people have opinions about almost everything; other people have opinions about just some things; and still other people have very few opinions. What about you? Would you say you have opinions about almost everything, about many things, about some things, or about very few things?","DefaultChoices":false,"DataExportTag":"Q185","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Some people have opinions about almost everything; other people have opinions about just some thi...","Choices":{"1":{"Display":"Opinions about almost everything"},"2":{"Display":"About many things"},"3":{"Display":"About some things"},"4":{"Display":"About very few things"},"5":{"Display":"No answer / Prefer not to answer"}},"ChoiceOrder":["1","2","3","4","5"],"Randomization":{"Advanced":{"FixedOrder":["{~ScaleReversal~}","{~ScaleReversal~}","{~ScaleReversal~}","{~ScaleReversal~}","5"],"RandomSubSet":[],"RandomizeAll":[],"ScaleReversal":["1","2","3","4"],"TotalRandSubset":0,"Undisplayed":[]},"ConsistentScaleReversal":true,"EvenPresentation":false,"TotalRandSubset":"","Type":"Advanced"},"Validation":{"Settings":{"ForceResponse":"RequestResponse","ForceResponseType":"RequestResponse","Type":"None"}},"RecodeValues":{"1":"4","2":"3","3":"2","4":"1","5":"5"},"GradingData":[],"AnalyzeChoices":{"5":"No"},"Language":[],"NextChoiceId":6,"NextAnswerId":1,"QuestionID":"QID273"}},{"SurveyID":"SV_3k23UO2PJvuYb66","Element":"SQ","PrimaryAttribute":"QID274","SecondaryAttribute":"First of all, thank you for taking the time to take our survey. We would like to inform you about...","TertiaryAttribute":null,"Payload":{"QuestionText":"First of all, thank you for taking the time to take our survey. We would like to inform you about the news article you read at the beginning of the survey. <strong>Those two paragraphs you read in this text are purely fictional.</strong> The information in the text is not taken from real news. <strong>The cited news article does not reflect the truth</strong>. It is part of an experiment. The reason we want you to read this text before filling out the questionnaire is that we want to understand how your current beliefs in conspiracy theories in the text affect your attitudes towards democracy. Thanks for your participation.","DefaultChoices":false,"DataExportTag":"debriefing note","QuestionID":"QID274","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"First of all, thank you for taking the time to take our survey. We would like to inform you about...","Choices":{"4":{"Display":"Proceed and complete the s