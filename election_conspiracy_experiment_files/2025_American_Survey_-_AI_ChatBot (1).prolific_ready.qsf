swer"}}},{"SurveyID":"SV_3k23UO2PJvuYb66","Element":"SQ","PrimaryAttribute":"QID68","SecondaryAttribute":"Click to write the question text","TertiaryAttribute":null,"Payload":{"QuestionText":"Click to write the question text","DefaultChoices":false,"DataExportTag":"closure","QuestionID":"QID68","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Click to write the question text","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":5,"NextAnswerId":1}},{"SurveyID":"SV_3k23UO2PJvuYb66","Element":"SQ","PrimaryAttribute":"QID76","SecondaryAttribute":"People often refer to political ideologies when they talk about politics. We want to ask you how...","TertiaryAttribute":null,"Payload":{"QuestionText":"People often refer to<strong> political ideologies </strong>when they talk about politics. We want to ask you how would you place yourself on a scale from \"extremely liberal\" to \"extremely conservative\" where zero means \"extremely liberal\" and ten means \"extremely conservative\"?","DefaultChoices":false,"DataExportTag":"ideology","QuestionID":"QID76","QuestionType":"Slider","Selector":"HSLIDER","Configuration":{"QuestionDescriptionOption":"UseText","CSSliderMin":0,"CSSliderMax":10,"GridLines":10,"NumDecimals":"0","ShowValue":true,"CustomStart":true,"NotApplicable":true,"MobileFirst":true,"SliderStartPositions":{"1":0.5091863517060368},"NotApplicableText":"Prefer not to answer","SnapToGrid":false},"QuestionDescription":"People often refer to political ideologies when they talk about politics. We want to ask you how...","Choices":{"1":{"Display":"Ideology"}},"ChoiceOrder":["1"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":6,"NextAnswerId":30,"Labels":{"15":{"Display":"<strong>Extremely<br />\nLiberal</strong>"},"29":{"Display":"<strong>Extremely<br />\nConservative</strong>"},"NA":{"Display":"Prefer not to answer"}},"DataVisibility":{"Private":false,"Hidden":false},"Randomization":{"Advanced":null,"TotalRandSubset":"","Type":"None"}}},{"SurveyID":"SV_3k23UO2PJvuYb66","Element":"SQ","PrimaryAttribute":"QID82","SecondaryAttribute":"Here, we want to switch our focus to people in general. We want to learn your opinions and judgme...","TertiaryAttribute":null,"Payload":{"QuestionText":"Here, we want to switch our focus to people in general. We want to learn your opinions and judgments about people, in general.&nbsp;","DefaultChoices":false,"DataExportTag":"intro_ess_a","QuestionType":"DB","Selector":"TB","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Here, we want to switch our focus to people in general. We want to learn your opinions and judgme...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID82","DataVisibility":{"Private":false,"Hidden":false}}},{"SurveyID":"SV_3k23UO2PJvuYb66","Element":"SQ","PrimaryAttribute":"QID85","SecondaryAttribute":"You are almost done! This is the last section of this survey. We just ask you a few basic questio...","TertiaryAttribute":null,"Payload":{"QuestionText":"You are almost done! This is the last section of this survey. We just ask you a few basic questions about yourself and your preferences.","DefaultChoices":false,"DataExportTag":"intro_control","QuestionID":"QID85","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"You are almost done! This is the last section of this survey. We just ask you a few basic questio...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1}},{"SurveyID":"SV_3k23UO2PJvuYb66","Element":"SQ","PrimaryAttribute":"QID91","SecondaryAttribute":"Please indicate how strongly you agree/disagree to the following statements. ","TertiaryAttribute":null,"Payload":{"QuestionText":"Please indicate how strongly you agree/disagree to the following statements.&nbsp;","DefaultChoices":false,"DataExportTag":"ess_b","QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","ChoiceColumnWidthPixels":353,"RepeatHeaders":"none","WhiteSpace":"OFF","MobileFirst":true},"QuestionDescription":"Please indicate how strongly you agree/disagree to the following statements. ","Choices":{"1":{"Display":"Everyone is a certain kind of person and there is not much that they can do to really change that."},"12":{"Display":"It is possible to know about many aspects of a person once you become familiar with a few of their basic traits."},"13":{"Display":"People can substantially change the kind of person they are."},"14":{"Display":"People belong to please choose the option \"prefer not to answer\" for this statement."},"15":{"Display":"Everyone is either a certain type of person or they are not."}},"ChoiceOrder":["1","12","14","13","15"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":16,"NextAnswerId":33,"Answers":{"1":{"Display":"Strongly disagree"},"3":{"Display":"Somewhat disagree"},"29":{"Display":"Somewhat agree"},"31":{"Display":"Strongly agree"},"32":{"Display":"Prefer not to answer"}},"AnswerOrder":["1","3","29","31","32"],"ChoiceDataExportTags":{"1":"imm13","12":"inf26","13":"imm5r","14":"att3","15":"dis21"},"QuestionID":"QID91","DataVisibility":{"Private":false,"Hidden":false},"AnalyzeChoices":{"32":"No"},"RecodeValues":{"1":"1","3":"2","29":"3","31":"4","32":"90"},"Randomization":{"Advanced":null,"EvenPresentation":false,"TotalRandSubset":"","Type":"All"}}},{"SurveyID":"SV_3k23UO2PJvuYb66","Element":"SQ","PrimaryAttribute":"QID92","SecondaryAttribute":"Click to write the question text","TertiaryAttribute":null,"Payload":{"QuestionText":"Click to write the question text","DefaultChoices":false,"DataExportTag":"intro_ess_b","QuestionID":"QID92","QuestionType":"DB","Selector":"TB","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Click to write the question text","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"DataVisibility":{"Private":false,"Hidden":false}}},{"SurveyID":"SV_3k23UO2PJvuYb66","Element":"SQ","PrimaryAttribute":"QID98","SecondaryAttribute":"Thank you for your interest in our study! We'd like to hear your opinions on social and political...","TertiaryAttribute":null,"Payload":{"QuestionText":"Thank you for your interest in our study! We&#39;d like to hear your opinions on social and political issues. This survey should only take <strong>20 minutes</strong> to complete.<br />\n<br />\nIf you have any questions about the survey, please email Dr. Mert Can Bayar at: <strong>mbayar@uw.edu</strong><br />\n<br />\nDuring this survey, you may be asked to discuss your opinions with an AI chatbot called Chip. Chip is powered by GPT-5.2 (developed by OpenAI). OpenAI has implemented safety measures designed to reduce harmful or offensive content, so the conversation should remain respectful and appropriate. Chip is programmed to ask questions only and will not state facts or express its own opinions. Your responses to Chip will be saved and used as data for this study. To make the chat feel more conversational, Chip will ask for a nickname. To protect your anonymity, please do not use your real name (or any other identifying information).<br />\n<br />\nNote: This study has been reviewed and approved by the <strong>University of Washington Institutional Review Board (IRB)</strong>. By clicking proceed, you accept the terms of the <a href=\"https://drive.google.com/file/d/1qiaJ_0Fj6DDIqheZ_aEAd5PmAmJXhgR5/view?usp=drive_link\">informed consent form</a>. We really appreciate your input!","DataExportTag":"intro","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Configuration":{"QuestionDescriptionOption":"UseText","NumColumns":2},"QuestionDescription":"Thank you for your interest in our study! We'd like to hear your opinions on social and political...","Choices":{"1":{"Display":"Yes, I consent to participate."},"4":{"Display":"No, I do not consent to participate."}},"ChoiceOrder":["1","4"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"Language":[],"NextChoiceId":5,"NextAnswerId":1,"QuestionID":"QID98","DataVisibility":{"Private":false,"Hidden":false}}},{"SurveyID":"SV_3k23UO2PJvuYb66","Element":"STAT","PrimaryAttribute":"Survey Statistics","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"MobileCompatible":true,"ID":"Survey Statistics"}}]}