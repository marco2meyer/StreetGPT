# Copy to .env and adjust values for local/dev/prod

# App
APP_NAME=streetgpt
# Single password for app access
PASSWORD=
# Public hostname that should serve the HTTPS site.
# The default uses sslip.io to map your server IP to a real hostname.
SITE_HOST=91-98-77-78.sslip.io
## Optional path to system messages YAML (inside container path)
SYSTEM_MESSAGES_FILE=/app/config/system_messages.yaml

# OpenAI
OPENAI_API_KEY=sk-your-key
## Model selection; defaults to "gpt-5" if not set
OPENAI_MODEL=gpt-5

# Prolific / Qualtrics
PROLIFIC_API=
## Optional explicit public chatbot URL. If unset, the setup script derives it
## from SITE_HOST and will turn raw IPv4 hosts into sslip.io hostnames.
CHATBOT_PUBLIC_URL=
## Fill this with the live anonymous Qualtrics link after you import/publish the
## QSF, then use it when creating the Prolific study.
QUALTRICS_SURVEY_URL=

# Mongo
MONGO_DB_NAME=streetgpt
# Root password for Mongo (only used by the mongo container)
MONGO_ROOT_PASSWORD=change-this-root-pass
# App user created by mongo-init/init.js
MONGO_USER=appuser
MONGO_PASSWORD=apppassword
